# =============================================================================
# Docker environment — copy this file to .env when using Docker Compose
#
#   cp .env.docker .env
#
# KEY DIFFERENCES from the default .env:
#   - DB_HOST points to the "postgres" service (not 127.0.0.1)
#   - APP_URL uses port 8000 (mapped by docker-compose.yml)
# =============================================================================

APP_NAME="Gestion De Invitaciones"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_PORT=8000

# ---------------------------------------------------------------------------
# Database — PostgreSQL (service name = "postgres")
# ---------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=gestiondeinvitaciones
DB_USERNAME=laravel
DB_PASSWORD=secret

# ---------------------------------------------------------------------------
# Session / Cache / Queue
# ---------------------------------------------------------------------------
SESSION_DRIVER=database
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# ---------------------------------------------------------------------------
# Redis (phpredis) — service name matches docker-compose service "redis"
# ---------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Mail — log driver for local development
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Broadcasting / other defaults
# ---------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
LOG_CHANNEL=stack
LOG_LEVEL=debug
