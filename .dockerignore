# Version control
.git
.gitignore
.gitattributes

# Dependencies (installed inside the image)
vendor/
node_modules/

# Frontend / Vite — not needed for an API-only project
public/build/
public/hot
resources/js/
resources/css/
vite.config.js
package.json
package-lock.json

# Environment files (never bake secrets into the image)
.env
.env.*
!.env.example

# Docker files themselves
Dockerfile
docker-compose*.yml
# Exclude only the parts of docker/ not needed inside the image
docker/nginx/
docker/postgres/

# Tests & CI
tests/
phpunit.xml
.github/

# IDE & editor config
.editorconfig
.idea/
.vscode/
*.code-workspace

# OS artifacts
.DS_Store
Thumbs.db

# Logs and cache
storage/logs/*.log
bootstrap/cache/*.php

# Laravel Pint / Pail (dev tools)
.php-cs-fixer.cache
